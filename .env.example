# Copy to .env and fill in. Never commit .env.

# --- Data directory (paper state, journals, backtest output) ---
# Override with FARB_HOME (primary) or DCA_HOME (legacy fallback).
# Default: <project>/data
# FARB_HOME=/path/to/your/data

# Subfolder under FARB_HOME for strategy instances (default: funding-arb)
# FARB_RUNS_NAMESPACE=funding-arb
# Deprecated: DCA_RUNS_NAMESPACE also works as fallback

# --- Exchange API (live only; paper dry-run needs no keys) ---
# Bitget
# BITGET_API_KEY=
# BITGET_SECRET_KEY=
# BITGET_PASSPHRASE=

# Binance
# BINANCE_API_KEY=
# BINANCE_API_SECRET=

# OKX
# OKX_API_KEY=
# OKX_SECRET_KEY=
# OKX_PASSPHRASE=

# Bybit
# BYBIT_API_KEY=
# BYBIT_SECRET_KEY=

# Hyperliquid (perp DEX; scan needs no keys, live trading needs sibling repo)
# HYPERLIQUID_API_KEY=          # wallet address 0x...
# HYPERLIQUID_API_SECRET=       # private key 0x...
# HYPERLIQUID_NETWORK=mainnet   # or testnet (api.hyperliquid-testnet.xyz)
# HYPERLIQUID_BASE_URL=         # full override of the Info/Exchange host

# Aster (perp DEX; Binance-fapi clone, HMAC keys; scan needs no keys)
# ASTER_API_KEY=
# ASTER_API_SECRET=

# EdgeX (perp DEX; scan needs no keys, trading needs the V2 SDK + these)
# EDGEX_ACCOUNT_ID=
# EDGEX_TRADING_PRIVATE_KEY=
# EDGEX_NETWORK=mainnet         # or testnet
# EDGEX_BASE_URL=https://edgex-prod-v2.edgex.exchange   # trading host (overrides network)
# EDGEX_ASSET_BASE_URL=https://spot.edgex.exchange      # asset host (overrides network)
# EDGEX_PUBLIC_BASE_URL=https://pro.edgex.exchange      # public scan host (overrides network)
# NOTE: EdgeX testnet sits behind Cloudflare Access; if testnet scan/trade is
# not reachable, set the *_BASE_URL hosts explicitly to your testnet endpoints.
# Verify: python3 scripts/tools/verify_edgex_live.py [--read-account]

# Lighter (perp DEX; scan needs no keys, trading needs lighter-sdk)
# LIGHTER_API_PRIVATE_KEY=
# LIGHTER_ACCOUNT_INDEX=        # numeric index, or set LIGHTER_L1_ADDRESS
# LIGHTER_L1_ADDRESS=           # 0x... auto-resolves the account index
# LIGHTER_NETWORK=mainnet       # or testnet (testnet.zklighter.elliot.ai)
# LIGHTER_BASE_URL=             # full override of the API host

# dYdX v4 (perp DEX; scan uses public indexer, no keys needed)
# Live trading is gated: requires dydx-v4-client SDK + all three below.
# DYDX_ENABLE_LIVE=1            # explicit opt-in; live order builder pending testnet rehearsal
# DYDX_MNEMONIC=                # 24-word BIP-39 mnemonic
# DYDX_ADDRESS=                 # dydx1... bech32 address
# DYDX_SUBACCOUNT_NUMBER=0
# DYDX_NETWORK=mainnet          # or testnet
# DYDX_INDEXER_HOST=            # override indexer endpoint
# DYDX_NODE_HOST=               # override node gRPC target
# Basis-blend index proxy (orderbook mid instead of oracle) in fetch_all:
# DYDX_INDEX_MID=1
# DYDX_MID_BASES=BTC,ETH,SOL    # override the default liquid-bases whitelist
# DYDX_MID_WORKERS=4

# --- Notifications (optional; Telegram) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- Force paper / live for the executors ---
# FARB_DRY_RUN=1               # force paper mode (legacy DCA_DRY_RUN still honored)
# FARB_LIVE=1                  # force live mode  (legacy DCA_LIVE still honored)
