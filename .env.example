# Copy to .env and fill in. Never commit .env.

# --- Data directory (paper state, journals, backtest output) ---
# Default: <project>/data
# DCA_HOME=/path/to/your/data

# Subfolder under DCA_HOME for strategy instances (default: cex-bitget)
# DCA_RUNS_NAMESPACE=cex-bitget

# --- Exchange API (live only; paper dry-run needs no keys) ---
# Bitget
# BITGET_API_KEY=
# BITGET_SECRET_KEY=
# BITGET_PASSPHRASE=

# Binance
# BINANCE_API_KEY=
# BINANCE_API_SECRET=

# --- Funding-Arb cron integration (optional) ---
# FUNDING-ARB_NODE=$(which node)
# FUNDING-ARB_BIN=/path/to/funding-arb/funding-arb.mjs
# FUNDING-ARB_CRON_AGENT=tg-main
# FUNDING-ARB_CRON_TZ=Asia/Shanghai

# Telegram notify target (required if using install_*_cron.sh with --announce)
# QUANT_CRON_TELEGRAM_TO=

# Report cadence (runs between comparison table pushes)
# DCA_REPORT_NOTIFY_RUNS=24

# Force dry-run / live for run_dca.py
# DCA_DRY_RUN=1
# DCA_LIVE=1
